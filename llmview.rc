// Microsoft Visual C++ generated resource script.
#include "Resource.h"

#define IDM_VIEW_TRANSLATE 40024

#define APSTUDIO_READONLY_SYMBOLS
#include "winres.h"
#undef APSTUDIO_READONLY_SYMBOLS

#if !defined(AFX_RESOURCE_DLL) || defined(AFX_TARG_ENU)
LANGUAGE LANG_ENGLISH, SUBLANG_ENGLISH_US

IDI_APP ICON "Icon.ico"

IDR_MENU_BAR MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&Open\tO",               IDM_FILE_OPEN
        MENUITEM "&Refresh\tR",            IDM_FILE_REFRESH
        MENUITEM "LLM &Translate\tT",      IDM_VIEW_TRANSLATE, CHECKED
        MENUITEM SEPARATOR
        MENUITEM "&Close\tQ",              IDM_FILE_EXIT
    END
    POPUP "Help"
    BEGIN
        MENUITEM "About",                  IDM_HELP_ABOUT
    END
END

IDR_ACCELERATOR ACCELERATORS
BEGIN
    "O", IDM_FILE_OPEN, VIRTKEY, NOINVERT
    "R", IDM_FILE_REFRESH, VIRTKEY, NOINVERT
    "T", IDM_VIEW_TRANSLATE, VIRTKEY, NOINVERT
    "Q", IDM_FILE_EXIT, VIRTKEY, NOINVERT
END

VS_VERSION_INFO VERSIONINFO
 FILEVERSION 1,0,0,0
 PRODUCTVERSION 1,1,0,15
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "dodo"
            VALUE "FileDescription", "Markdown viewer with LLM translation"
            VALUE "FileVersion", "1,0,0,0"
            VALUE "InternalName", "llmview.exe"
            VALUE "OriginalFilename", "llmview.exe"
            VALUE "ProductName", "LLM Markdown Viewer"
            VALUE "ProductVersion", "1,1,0,15"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END

IDD_ABOUTBOX DIALOGEX 0, 0, 270, 114
STYLE DS_SYSMODAL | DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About llmview"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    DEFPUSHBUTTON   "OK",IDOK,210,120,50,14
    LTEXT           "By dodo, 2026. Forked from mdview with LLM translation.",IDC_STATIC,50,16,188,16
    LTEXT           "Version 1.0.0.0",IDC_STATIC,50,38,188,16
    LTEXT           "Uses llmview.ini next to the executable for provider settings.",IDC_STATIC,50,60,220,16
    ICON            IDI_APP,IDC_STATIC,16,16,49,49
END

STRINGTABLE
BEGIN
    IDS_APP                 "llmview"
    IDS_MENU_FILE_EXIT      "Close Application"
    IDS_MENU_HELP_ABOUT     "Application Information"
END

#endif
