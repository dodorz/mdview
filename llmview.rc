    IDS_STATUS_DOCUMENT_LOADED      "Document loaded."
    IDS_STATUS_AUTOSAVED            "Translated file saved automatically after full translation."
    IDS_STATUS_TRANSLATED_SAVED     "Translated file saved."
    IDS_STATUS_PARTIAL_SAVED        "Partially translated file saved."
    IDS_STATUS_DEFERRED_SAVE        "Full translation will continue in background and save automatically."
    IDS_STATUS_PREVIEW_RENDERING    "Preview loaded, rendering full document..."
    IDS_MSG_AUTOSAVE_FAILED         "Failed to save the translated file automatically."
    IDS_MSG_NO_DOCUMENT             "No document is currently open."
    IDS_MSG_SAVE_FAILED             "Failed to save the translated file."
    IDS_MSG_WINDOW_REG_FAILED       "Window Registration Failed!"
    IDS_MSG_WINDOW_CREATE_FAILED    "Window Creation Failed!"
    IDS_DIALOG_PARTIAL_MAIN         "Save translated file"
    IDS_DIALOG_PARTIAL_CONTENT      "Current document is about %d%% translated.\n\nOK saves the current result now.\nCancel aborts saving.\nSave Later lets you choose the path now and automatically save after translation finishes."
    IDS_DIALOG_PARTIAL_FALLBACK     "Current document is only partially translated.\n\nYes saves the current result now.\nNo cancels saving.\nCancel chooses a path now and saves automatically after translation finishes."
    IDS_BTN_SAVE_LATER              "Save Later"
END

LANGUAGE LANG_CHINESE, SUBLANG_CHINESE_SIMPLIFIED

IDR_MENU_BAR MENU
BEGIN
    POPUP "文件(&F)"
    BEGIN
        MENUITEM "打开(&O)\tO",            IDM_FILE_OPEN
        MENUITEM "保存翻译结果(&S)\tS",    IDM_FILE_SAVE_TRANSLATED
        MENUITEM "刷新(&R)\tR",            IDM_FILE_REFRESH
        MENUITEM "LLM 翻译(&T)\tT",        IDM_VIEW_TRANSLATE, CHECKED
        MENUITEM SEPARATOR
        MENUITEM "关闭(&Q)\tQ",            IDM_FILE_EXIT
    END
    POPUP "帮助(&H)"
    BEGIN
        MENUITEM "关于",                   IDM_HELP_ABOUT
    END
END

IDR_ACCELERATOR ACCELERATORS
BEGIN
    "O", IDM_FILE_OPEN, VIRTKEY, NOINVERT
    "R", IDM_FILE_REFRESH, VIRTKEY, NOINVERT
    "S", IDM_FILE_SAVE_TRANSLATED, VIRTKEY, NOINVERT
    "T", IDM_VIEW_TRANSLATE, VIRTKEY, NOINVERT
    "Q", IDM_FILE_EXIT, VIRTKEY, NOINVERT
END

IDD_ABOUTBOX DIALOGEX 0, 0, 270, 114
