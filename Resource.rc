/////////////////////////////////////////////////////////////////////////////
//
// Icon
//

// Icon with lowest ID value placed first to ensure application icon
// remains consistent on all systems.
IDI_APP                 ICON                    "Icon.ico"

/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MENU_BAR MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&Open\tO",               IDM_FILE_OPEN
        MENUITEM "&Refresh\tR",            IDM_FILE_REFRESH
                MENUITEM SEPARATOR
        MENUITEM "&Close\tQ",               IDM_FILE_EXIT
    END
    POPUP "Help"
    BEGIN
        MENUITEM "About",                       IDM_HELP_ABOUT
    END
END



IDR_ACCELERATOR ACCELERATORS
BEGIN
	"O",            IDM_FILE_OPEN,     VIRTKEY, NOINVERT
	"R",            IDM_FILE_REFRESH,  VIRTKEY, NOINVERT
	"Q",            IDM_FILE_EXIT,     VIRTKEY, NOINVERT
END

/////////////////////////////////////////////////////////////////////////////
//
// Version
//

VS_VERSION_INFO VERSIONINFO
 FILEVERSION 1,0,3,9
 PRODUCTVERSION 1,0,3,9
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "dodo"
            VALUE "FileDescription", "Markdown viewer fork (mdview)"
            VALUE "FileVersion", "1,0,3,9"
            VALUE "InternalName", "mdview.exe"
            VALUE "LegalCopyright", "Copyright (C) 2026 dodo"
            VALUE "OriginalFilename", "mdview.exe"
            VALUE "ProductName", "Markdown Viewer"
            VALUE "ProductVersion", "1,0,3,9"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END


/////////////////////////////////////////////////////////////////////////////
//
// Dialog
//

IDD_ABOUTBOX DIALOGEX 0, 0, 270, 150
STYLE DS_SYSMODAL | DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About Markdown Viewer"
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    DEFPUSHBUTTON   "OK",IDOK,210,120,50,14
    LTEXT           "By dodo, 2026 (forked from Thomas Fuhringer's original project)",IDC_STATIC,50,16,188,16
    LTEXT           "Version 1.0.3.9",IDC_STATIC,50,38,188,16
    LTEXT           "https://github.com/thomasfuhringer/markdownviewer",IDC_STATIC,50,60,220,16
    ICON            IDI_APP,IDC_STATIC,16,16,49,49
END


